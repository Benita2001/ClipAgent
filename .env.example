# Port for the Express server
PORT=3000

# Local directory where uploaded video files are temporarily stored this phase
TEMP_UPLOAD_DIR=./tmp/uploads

# Max accepted upload size in megabytes
MAX_UPLOAD_MB=500

# Groq API key for Whisper transcription (https://console.groq.com)
GROQ_API_KEY=

# Optional: Groq Whisper model to use (defaults to whisper-large-v3)
GROQ_WHISPER_MODEL=whisper-large-v3

# Optional: Groq chat model for ranking moments (defaults to openai/gpt-oss-120b, a reasoning model)
GROQ_RANKING_MODEL=openai/gpt-oss-120b

# Supabase project URL, e.g. https://xxxxxxxxxxxx.supabase.co
SUPABASE_URL=

# Supabase service_role key (server-side only — never expose to a client/browser)
SUPABASE_SERVICE_KEY=

# Optional: Supabase Storage bucket for finished clips (created automatically as public if missing)
SUPABASE_STORAGE_BUCKET=clips

# Local directory where cut clips are written before upload
CLIPS_OUTPUT_DIR=./output/clips
