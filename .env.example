# Port for the Express server
PORT=3000

# Optional canonical public base URL used when constructing job status links
PUBLIC_BASE_URL=https://clipagent-n1wx.onrender.com

# Local directory where uploaded video files are temporarily stored this phase
TEMP_UPLOAD_DIR=./tmp/uploads

# Max accepted upload size in megabytes
MAX_UPLOAD_MB=500

# Optional: remote JSON videoUrl download limits
REMOTE_VIDEO_DOWNLOAD_TIMEOUT_MS=120000
REMOTE_VIDEO_MAX_BYTES=524288000
REMOTE_VIDEO_MAX_REDIRECTS=3

# Groq API key for Whisper transcription (https://console.groq.com)
GROQ_API_KEY=

# Optional: Groq Whisper model to use (defaults to whisper-large-v3)
GROQ_WHISPER_MODEL=whisper-large-v3

# Optional: Groq chat model for ranking moments (defaults to openai/gpt-oss-120b, a reasoning model)
GROQ_RANKING_MODEL=openai/gpt-oss-120b

# Optional: timeout for each Groq transcription or ranking request (milliseconds)
GROQ_TIMEOUT_MS=120000

# Optional: Gemini API key used only when Groq ranking exhausts its retries
GEMINI_API_KEY=

# Optional: timeout for each Gemini ranking request (milliseconds)
GEMINI_TIMEOUT_MS=60000

# Supabase project URL, e.g. https://xxxxxxxxxxxx.supabase.co
SUPABASE_URL=

# Supabase service_role key (server-side only — never expose to a client/browser)
SUPABASE_SERVICE_KEY=

# Optional: Supabase Storage bucket for finished clips (created automatically as public if missing)
SUPABASE_STORAGE_BUCKET=clips

# Optional: timeout for each Supabase network request (milliseconds)
SUPABASE_TIMEOUT_MS=90000

# Local directory where cut clips are written before upload
CLIPS_OUTPUT_DIR=./output/clips

# x402 payment gate on /clip (see services/x402Config.js), via the official
# @okxweb3/x402-express + x402-evm + x402-core SDK. Credentials are a standard
# OKX API key — create one at https://web3.okx.com/onchainos/dev-portal
# (same portal referenced elsewhere for personal rate-limit relief / wallet
# export / policy settings). Left unset, the SDK's facilitator calls will fail
# closed (no payment ever verified as valid without real credentials).
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=

# Optional: x402 facilitator initialization retry timing (milliseconds)
X402_INIT_RETRY_BASE_MS=1000
X402_INIT_RETRY_MAX_MS=30000
